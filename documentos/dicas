       ft_strtrim.c ft_split.c ft_itoa.c ft_strmapi.c ft_striteri.c \
       ft_putchar_fd.c ft_putstr_fd.c ft_putendl_fd.c ft_putnbr_fd.c

# Arquivos objeto
OBJS = $(SRCS:.c=.o)

# Regra padrão
all: $(NAME)

# Cria a biblioteca
$(NAME): $(OBJS)
	$(AR) $(NAME) $(OBJS)

# Compila os arquivos .c em .o
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
ser
# Limpa os arquivos objeto
clean:
	$(RM) $(OBJS)

# Limpa objeto e a biblioteca
fclean: clean
	$(RM) $(NAME)

# Reinicia a compilação
re: fclean all

.PHONY: all clean fclean re

