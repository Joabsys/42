# Nome da biblioteca
NAME = libft.a

# Compilador e flags
CC = cc
CFLAGS = -Wall -Wextra -Werror -I includes

# Comandos
AR = ar rcs
RM = rm -f

# Diretórios
SRCDIR = srcs
INCDIR = includes

# Arquivos fonte
SRCS = ft_putchar.c \
       ft_putstr.c \
       ft_strcmp.c \
       ft_strlen.c \
       ft_swap.c

# Caminho completo dos fontes
SRC = $(addprefix $(SRCDIR)/, $(SRCS))

# Objetos
OBJS = $(SRC:.c=.o)

# Regra padrão
all: $(NAME)

# Criação da biblioteca
$(NAME): $(OBJS)
	$(AR) $(NAME) $(OBJS)

# Compilação dos objetos
$(SRCDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# Remove objetos
clean:
	$(RM) $(OBJS)

# Remove objetos e biblioteca
fclean: clean
	$(RM) $(NAME)

# Recompila tudo
re: fclean all

.PHONY: all clean fclean re
